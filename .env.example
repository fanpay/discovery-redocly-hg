# Copy this file to .env and fill in values for your environment.
# These are used by the switch-env.sh script and can also be
# referenced inside redocly configs with $ENV.VARIABLE_NAME syntax.

# Set to: dev | qa | staging | production
REDOCLY_ENV=dev

# Override the API base URL directly (optional — each config file
# already has a default server URL for its environment).
API_BASE_URL=https://dev-api.museum.example.com/v1
